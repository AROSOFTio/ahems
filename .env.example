APP_NAME=AHEMS
APP_PORT=3003
CLIENT_PORT=80
SERVER_PORT=5000
# Use host.docker.internal when MySQL is managed outside Docker on the same VPS through aaPanel.
# If your aaPanel MySQL is on another server, replace this with that server IP or hostname.
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=ahems
# Set these to the database and user you create in aaPanel.
MYSQL_USER=ahems_user
MYSQL_PASSWORD=StrongPassword123!
# Only used if you intentionally start the optional local MySQL Docker profile.
MYSQL_ROOT_PASSWORD=RootStrongPassword123!
MYSQL_HOST_PORT=3307
JWT_SECRET=replace-with-a-strong-jwt-secret
JWT_EXPIRES_IN=12h
CLIENT_PUBLIC_URL=https://ahems.arosoft.io
VITE_API_BASE_URL=/api
